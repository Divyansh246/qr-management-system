# ═══════════════════════════════════════════════════════════════
# HimShakti Batch Traceability System — Environment Variables
# Intern 2 Backend (port 5001)
# Last Updated: 2026-06-25
# ═══════════════════════════════════════════════════════════════
# Copy this file to backend/.env and fill in the real values.
# NEVER commit the real .env file to version control.

# ── Database ───────────────────────────────────────────────────
# MongoDB Atlas connection string (provided by Intern 1 — cluster admin)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/himshakti?retryWrites=true&w=majority

# ── Server ─────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── URLs ───────────────────────────────────────────────────────
# Encoded into every QR code — must be reachable by phone cameras
PUBLIC_BASE_URL=http://localhost:5001
# Allowed CORS origin for the React frontend
FRONTEND_URL=http://localhost:5173

# ── AI ─────────────────────────────────────────────────────────
# Primary: Google Gemini
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_YOUR_KEY_HERE
# Hours between allowed live Gemini API calls (default: 4)
GEMINI_CACHE_TTL_HOURS=4

# Fallback: NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_key_here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ── Auth ───────────────────────────────────────────────────────
# Random secret for signing JWTs — keep private
JWT_SECRET=your_jwt_secret_here

# ── Frontend .env (create separately in frontend/.env) ─────────
# VITE_API_BASE_URL=http://localhost:5001
